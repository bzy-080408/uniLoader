	chosen {
		linux,initrd-end = "\vtL";
		linux,initrd-start = <0x7c00000>;
		bootargs = "loglevel=4 initcall_debug=n page_tracker=on slub_min_objects=16 unmovable_isolate1=2:192M,3:224M,4:256M printktimer=0xfff0a000,0x534,0x538 androidboot.selinux=enforcing buildvariant=user androidboot.swtype=normal fastboot_version=Chipset-CHICAGO9.0.1.6(02N1)_FASTBOOT setup_logctl=0 fastbootdmd=0 enter_recovery=1 enter_erecovery=0 androidboot.mode=normal pmu_nv_addr=0x20b20014 low_volt_flag=1 usb_macbt=normal boardid=0x00001585 androidboot.dtbo_idx=0 normal_reset_type=BR_KEY_VOLUMN_UP  TP_COLOR=135  COLOR_TMP=0 LCD_DENSITY=0  DDIC_INFO= ddr_die=2048M@0M ddr_die=2048M@2048M  productid=0x3a001411 efuse_status=0 androidboot.serialno=3HX5T17512005015 himntn=01111111111110100010110000000000000000101000 boot_slice=0x000b262c reboot_reason=COLDBOOT exception_subtype=no last_bootup_keypoint=32 recovery_update=0 bootlock=unlocked hw_bfm_enable=0 hw_bfr_enable=1 ddr_density=2 swiotlb=2 androidboot.odm.conn.chiptype=bcm43xx androidboot.odm.conn.schiptype=bcm43455 mdmreglogbase=0x00000000 mdmreglogsize=0x00000000 modem_socp_enable=0 androidboot.hardware=hi3660 androidboot.veritymode=enforcing tpcolor=gold androidboot.verifiedbootstate=orange ufs_product_name=KLUCG4J1EB-B0B1  format_data=1 cpu_buck_reg=0x;;  LCD_ID=5 androidboot.vendor.ddrsize=4 oba_version=20190104215422_OBA_VERSION kce_status=1  androidboot.vercnt1=2 bl1_time=2182 bl2_time=22350 logo_time=6512 dsm_notify=1 backcolor=champagne vendorcountry=all/cn devmodel=MHA-AL00 userHotaUpdate=success_2 androidboot.product.hardware.sku=MHA-AL00 userlock=locked androidboot.oemmode=rd product_phase=pre_delivery  console=ttyS0 ";
		kaslr-seed = <0x00 0x00>;
	};

