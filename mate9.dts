	firmware {

		android {
			compatible = "android,firmware";
			boot_devices = "ff3b0000.ufs,hi_mci.0";

			vbmeta_huawei {
				compatible = "android,vbmeta";
				parts = "vbmeta,kernel,vendor,odm,cust,version,product,system,eng_system,eng_vendor,preload";
			};

			vbmeta_hisi {
				compatible = "android,vbmeta";
				parts = "vbmeta,kernel,vendor,odm,system,eng_system,eng_vendor";
			};

			fstab {
				compatible = "android,fstab";

				vendor {
					compatible = "android,vendor";
					dev = "/dev/block/by-name/vendor";
					type = "ext4";
					mnt_flags = "ro,barrier=1";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};

				odm {
					compatible = "android,odm";
					dev = "/dev/block/by-name/odm";
					type = "ext4";
					mnt_flags = "ro,barrier=1";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};
			};
		};

		huawei {
			compatible = "huawei,firmware";

			fstab {
				compatible = "huawei,fstab";

				dfx {
					compatible = "huawei,dfx";
					dev = "/dev/block/by-name/dfx";
					type = "emmc";
					mnt_flags = "defaults";
					fsmgr_flags = "defaults";
					status = "ok";
				};

				rrecord {
					compatible = "huawei,rrecord";
					dev = "/dev/block/by-name/rrecord";
					type = "emmc";
					mnt_flags = "defaults";
					fsmgr_flags = "defaults";
					status = "ok";
				};

				misc {
					compatible = "huawei,misc";
					dev = "/dev/block/by-name/misc";
					type = "emmc";
					mnt_flags = "defaults";
					fsmgr_flags = "defaults";
					status = "ok";
				};

				bfi {
					compatible = "huawei,bfi";
					dev = "/dev/block/by-name/bootfail_info";
					type = "emmc";
					mnt_flags = "defaults";
					fsmgr_flags = "defaults";
					status = "ok";
				};

				cust {
					compatible = "huawei,cust";
					dev = "/dev/block/by-name/cust";
					type = "ext4";
					mnt_flags = "ro";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};

				version {
					compatible = "huawei,version";
					dev = "/dev/block/by-name/version";
					type = "ext4";
					mnt_flags = "ro";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};

				product {
					compatible = "huawei,product";
					dev = "/dev/block/by-name/product";
					type = "ext4";
					mnt_flags = "ro";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};

				preload {
					compatible = "huawei,preload";
					dev = "/dev/block/by-name/preload";
					type = "ext4";
					mnt_flags = "ro";
					fsmgr_flags = "wait,avb";
					status = "ok";
				};
			};
		};
	};

