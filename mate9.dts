/dts-v1/;

/ {
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	model = "hi3660";
	compatible = "hisilicon,hi3660";
	interrupt-parent = <0x01>;
	hisi,boardid = <0x05 0x05 0x00 0x09>;
	hisi,boardname = "MHA_TUGL_VN2";
	hisi,modem_id = <0x3a001400>;
	hisi,sub_platform_info3 = "Kirin960";
	hisi,provider3 = "BALONG";
	hisi,sub_platform_info2 = "Kirin960";
	hisi,provider2 = "BALONG";
	hisi,sub_platform_info1 = "Kirin960";
	hisi,provider1 = "BALONG";
	hisi,sub_platform_info0 = "Kirin960";
	hisi,provider0 = "HUAWEI_K3";
	hisi,platform_num = <0x04>;
	hisi,gpu_arch = "mimir";
	hisi,camera_arch = "platform_v110";
	hisi,camera_arch_v120 = "platform_v120";

	memory@0 {
		device_type = "memory";
		reg = <0x00 0x00 0x00 0x80000000 0x00 0x80000000 0x00 0x60000000 0x02 0x00 0x00 0x20000000>;
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		graphic {
			size = <0x00 0x1e00000>;
			alignment = <0x00 0x100000>;
			alloc-ranges = <0x00 0x00 0x01 0x00>;
			compatible = "hisi_ion";
			heap-name = "carveout_gralloc";
			phandle = <0x22d>;
		};

		camera-mem {
			size = <0x00 0x28000000>;
			alignment = <0x00 0x400000>;
			alloc-ranges = <0x01 0x00 0x01 0x00>;
			compatible = "hisi-camera-pool";
			reusable;
			status = "disable";
			phandle = <0x2c9>;
		};

		hisi_cma {
			reg = <0x00 0x60000000 0x00 0x20000000>;
			compatible = "hisi-cma-pool";
			sec-attr = <0x00 0x20>;
			reusable;
			status = "ok";
		};

		fastboot-cma-mem {
			reg = <0x00 0x16c00000 0x00 0x1400000>;
			compatible = "shared-dma-pool";
			hisi,cma-sec;
			sec-attr = <0x00 0x00>;
			reusable;
			status = "ok";
			phandle = <0x236>;
		};

		cma_align2M {
			reg = <0x00 0x18000000 0x00 0x2000000>;
			compatible = "shared-dma-pool";
			order-per-bit = <0x09>;
			reusable;
			sec-attr = <0x00 0x10>;
			status = "ok";
			phandle = <0x237>;
		};

		cma_align4K {
			reg = <0x00 0x1a000000 0x00 0xc00000>;
			compatible = "shared-dma-pool";
			reusable;
			status = "ok";
			phandle = <0x2ca>;
		};

		isp-boot {
			reg = <0x00 0x1ac00000 0x00 0x2400000>;
			compatible = "shared-dma-pool";
			reusable;
			phandle = <0x25f>;
		};

		isp-boot-nocma {
			reg = <0x00 0x1d000000 0x00 0x100000>;
			no-map;
		};

		ivp {
			reg = <0x00 0x1d100000 0x00 0x100000>;
			no-map;
		};

		secos {
			reg = <0x00 0x1d200000 0x00 0x3000000>;
			no-map;
		};

		bl31 {
			reg = <0x00 0x20200000 0x00 0x200000>;
			no-map;
		};

		sensorhub-s {
			reg = <0x00 0x20400000 0x00 0x600000>;
			no-map;
		};

		pstore-mem {
			reg = <0x00 0x20a00000 0x00 0x100000>;
			phandle = <0x235>;
		};

		fka-mem {
			reg = <0x00 0x20b00000 0x00 0x3f000>;
			no-map;
		};

		mntndump {
			reg = <0x00 0x20b3f000 0x00 0x1000>;
			no-map;
		};

		fka-mem_part2 {
			reg = <0x00 0x20b40000 0x00 0x40000>;
			no-map;
		};

		sensorhub-share-mem {
			reg = <0x00 0x20b80000 0x00 0x80000>;
			no-map;
		};

		logo-buffer {
			reg = <0x00 0x21000000 0x00 0x3000000>;
			status = "ok";
		};

		kerneldump {
			reg = <0x00 0x40000000 0x00 0x20000000>;
			status = "disable";
		};

		app_no_allocate {
			reg = <0x00 0x00 0x00 0x1000>;
		};

		badpage {
			reg = <0x1110 0x00 0x00 0x1000>;
			bad-range = <0x00 0x24000000 0x00 0x40000000 0x00 0x90000000 0xffffffff 0xffffffff>;
			no-map;
			status = "disable";
		};

		tui-mem {
			size = <0x00 0x2000000>;
			alignment = <0x00 0x2000000>;
			alloc-ranges = <0x00 0x00 0x01 0x00>;
			compatible = "shared-dma-pool";
			reusable;
			status = "ok";
			phandle = <0x234>;
		};

		xmode-data {
			size = <0x00 0x1f400000>;
			alignment = <0x00 0x100000>;
			alloc-ranges = <0x00 0x00 0x01 0x00>;
			compatible = "modem_xmode_region";
			region-name = "xmode-data";
			status = "disabled";
			phandle = <0x286>;
		};

		modem-s {
			reg = <0x00 0x80000000 0x00 0x9200000>;
			no-map;
		};

		hifi-base {
			reg = <0x00 0x89200000 0x00 0xc00000>;
			no-map;
		};

		lpmx-core {
			reg = <0x00 0x89e00000 0x00 0x100000>;
			no-map;
		};

		lpmcu {
			reg = <0x00 0x89f00000 0x00 0x40000>;
			no-map;
		};

		align-reserved {
			reg = <0x00 0x89f40000 0x00 0xc0000>;
			no-map;
		};

		modem-share-mem {
			reg = <0x00 0x8a000000 0x00 0x500000>;
			no-map;
		};

		modem-socp {
			reg = <0x00 0x8a500000 0x00 0x1100000>;
			no-map;
			status = "disable";
		};

		hifi-data {
			reg = <0x00 0x8b600000 0x00 0x500000>;
			no-map;
		};

		bbox-mem {
			reg = <0x00 0x8bb00000 0x00 0x800000>;
			hisi,cma-mem;
			phandle = <0xf4>;
		};

		mperf {
			size = <0x00 0x900000>;
			alignment = <0x00 0x800000>;
			alloc-ranges = <0x00 0x00 0x01 0x00>;
			compatible = "hisi_mperf";
			status = "disable";
			phandle = <0x284>;
		};

		mdmlog {
			size = <0x00 0x3200000>;
			alignment = <0x00 0x100000>;
			alloc-ranges = <0x00 0x00 0x01 0x00>;
			compatible = "hisi_mdmlog";
			status = " disabled";
			phandle = <0x285>;
		};
